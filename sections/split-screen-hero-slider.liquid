    -webkit-backdrop-filter: blur(18px) saturate(140%);
    background: rgb(255 255 255 / 0.14);
    background-color: rgb(255 255 255 / 0.14);
    border: 1px solid rgb(255 255 255 / 0.18);
  }

  .sshs-content--glass:hover {
