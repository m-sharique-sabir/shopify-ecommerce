  }

  .sshs-cta-row--vertical {
    flex-direction: column;
  }

  .sshs-cta-row--vertical .sshs-btn {
    width: 100%;
    max-width: 280px;
  }

  @media screen and (max-width: 749px) {
    .sshs-cta-row--vertical-mobile {
      flex-direction: column;
    }

    .sshs-cta-row--vertical-mobile .sshs-btn {
      width: 100%;
      max-width: 280px;
    }

    .sshs-cta-row--vertical:not(.sshs-cta-row--vertical-mobile) {
      flex-direction: row;
    }
  }

  @media screen and (max-width: 749px) {
    .sshs-content[data-align-mobile="center"] .sshs-cta-row {
      justify-content: center;
    }

    .sshs-content[data-align-mobile="right"] .sshs-cta-row {
      justify-content: flex-end;
    }

    .sshs-content[data-align-mobile="left"] .sshs-cta-row {
      justify-content: flex-start;
    }

    .sshs-cta-row--vertical {
      align-items: center;
    }

    .sshs-content[data-align-mobile="left"] .sshs-cta-row--vertical {
      align-items: flex-start;
    }

    .sshs-content[data-align-mobile="right"] .sshs-cta-row--vertical {
      align-items: flex-end;
    }
  }

  .sshs-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: var(--sshs-button-radius, 14px);
    border: var(--sshs-button-border-width, 1px) solid var(--sshs-btn-border, currentColor);
    background: var(--sshs-btn-bg, transparent);
    color: var(--sshs-btn-color, currentColor);
    text-decoration: none;
    transition: transform 160ms ease, filter 160ms ease;
    will-change: transform;
  }

  @media screen and (max-width: 749px) {
    .sshs-btn {
      border-radius: var(--sshs-button-radius-mobile, var(--sshs-button-radius, 14px));
      border-width: var(--sshs-button-border-width-mobile, var(--sshs-button-border-width, 1px));
      border-color: var(--sshs-btn-border-mobile, var(--sshs-btn-border, currentColor));
      background: var(--sshs-btn-bg-mobile, var(--sshs-btn-bg, transparent));
      color: var(--sshs-btn-color-mobile, var(--sshs-btn-color, currentColor));
    }
  }

  .sshs-btn:hover {
    transform: translateY(-1px);
  }

  .sshs-media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: var(--sshs-media-radius, 0px);
    border: var(--sshs-media-border-width, 0px) solid var(--sshs-media-border, transparent);
    background: transparent;
    background-color: transparent;
    box-shadow: none;
    isolation: isolate;
    padding: var(--sshs-media-padding-y, 0) var(--sshs-media-padding-x, 0);
    margin-inline: var(--sshs-media-margin-x, 0);
    display: flex;
    justify-content: var(--sshs-media-align, center);
    align-items: var(--sshs-media-valign, center);
  }

  @media screen and (max-width: 749px) {
    .sshs-media {
      border-radius: var(--sshs-media-radius-mobile, var(--sshs-media-radius, 0px));
      border-width: var(--sshs-media-border-width-mobile, var(--sshs-media-border-width, 0px));
      border-color: var(--sshs-media-border-mobile, var(--sshs-media-border, transparent));
      padding: var(--sshs-media-padding-y-mobile, var(--sshs-media-padding-y, 0)) var(--sshs-media-padding-x-mobile, var(--sshs-media-padding-x, 0));
      margin-inline: var(--sshs-media-margin-x-mobile, var(--sshs-media-margin-x, 0));
      justify-content: var(--sshs-media-align-mobile, var(--sshs-media-align, center));
      align-items: var(--sshs-media-valign-mobile, var(--sshs-media-valign, center));
    }
  }

  .sshs-media__img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: var(--sshs-media-object-fit, cover);
    object-position: var(--sshs-media-bg-position, center center);
    opacity: var(--sshs-media-opacity, 1);
    filter: var(--sshs-media-filter, none);
    mix-blend-mode: var(--sshs-media-blend, normal);
    transform: scale(1.03);
    transition: transform 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
    position: relative;
    z-index: 1;
  }

  @media screen and (max-width: 749px) {
    .sshs-media__img {
      object-fit: var(--sshs-media-object-fit-mobile, var(--sshs-media-object-fit, cover));
      opacity: var(--sshs-media-opacity-mobile, var(--sshs-media-opacity, 1));
      filter: var(--sshs-media-filter-mobile, var(--sshs-media-filter, none));
      mix-blend-mode: var(--sshs-media-blend-mobile, var(--sshs-media-blend, normal));
    }
  }

  .sshs-media__wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }

  .sshs-media__video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: var(--sshs-media-object-fit, cover);
    object-position: var(--sshs-media-bg-position, center center);
    opacity: var(--sshs-media-opacity, 1);
    mix-blend-mode: var(--sshs-media-blend, normal);
    background: transparent;
    background-color: transparent;
  }

  @media screen and (max-width: 749px) {
    .sshs-media__video {
      object-fit: var(--sshs-media-object-fit-mobile, var(--sshs-media-object-fit, cover));
      opacity: var(--sshs-media-opacity-mobile, var(--sshs-media-opacity, 1));
      mix-blend-mode: var(--sshs-media-blend-mobile, var(--sshs-media-blend, normal));
    }
  }

  .sshs-media__img--mobile,
  .sshs-media__video--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .sshs-media__img--desktop,
    .sshs-media__video--desktop {
      display: none;
    }

    .sshs-media__img--mobile,
    .sshs-media__video--mobile {
      display: block;
    }
  }

  .swiper-slide-active .sshs-media__img {
    transform: scale(1);
  }

  .sshs-overlay {
    position: absolute;
    inset: 0;
    background: var(--sshs-overlay, transparent);
    opacity: var(--sshs-overlay-opacity, 0);
    pointer-events: none;
    z-index: 0;
  }

  @media screen and (max-width: 749px) {
    .sshs-overlay {
      background: var(--sshs-overlay-mobile, var(--sshs-overlay, transparent));
      opacity: var(--sshs-overlay-opacity-mobile, var(--sshs-overlay-opacity, 0));
    }
  }

  .sshs-media--floating .sshs-media__img {
    animation: sshsFloat 6s ease-in-out infinite;
  }

  @media screen and (max-width: 749px) {
    .sshs-media--floating-mobile .sshs-media__img {
      animation: sshsFloat 6s ease-in-out infinite;
    }

    .sshs-media--floating:not(.sshs-media--floating-mobile) .sshs-media__img {
      animation: none;
    }
  }

  .sshs-media__placeholder {
    width: 100%;
    height: 100%;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
    color: #888;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  @keyframes sshsFloat {
    0% {
      transform: translateY(0) scale(1.03);
    }
    50% {
      transform: translateY(-10px) scale(1.03);
    }
    100% {
      transform: translateY(0) scale(1.03);
    }
  }

  /* ════════════════════════════════════
     SCROLL ANIMATIONS
     ════════════════════════════════════ */

  /* Fade In Up Animation */
  @keyframes sshsFadeInUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fade In Down Animation */
  @keyframes sshsFadeInDown {
    from {
      opacity: 0;
      transform: translateY(-40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fade In Left Animation */
  @keyframes sshsFadeInLeft {
    from {
      opacity: 0;
      transform: translateX(-40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Fade In Right Animation */
  @keyframes sshsFadeInRight {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* Scale In Animation */
  @keyframes sshsScaleIn {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Zoom In Animation */
  @keyframes sshsZoomIn {
    from {
      opacity: 0;
      transform: scale(0.5);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Bounce In Animation */
  @keyframes sshsBounceIn {
    0% {
      opacity: 0;
      transform: scale(0.3);
    }
    50% {
      opacity: 1;
      transform: scale(1.05);
    }
    70% {
      transform: scale(0.9);
    }
    100% {
      transform: scale(1);
    }
  }

  /* Slide In From Bottom */
  @keyframes sshsSlideInBottom {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Slide In From Top */
  @keyframes sshsSlideInTop {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* Animation Classes - Initial State (hidden) */
  .sshs-animate--fade-up,
  .sshs-animate--fade-down,
  .sshs-animate--fade-left,
  .sshs-animate--fade-right,
  .sshs-animate--scale-in,
  .sshs-animate--zoom-in,
  .sshs-animate--bounce-in,
  .sshs-animate--slide-bottom,
  .sshs-animate--slide-top {
    opacity: 0;
  }

  /* Animation Classes - Animated State */
  .sshs-animate--fade-up.sshs-animated {
    animation: sshsFadeInUp var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--fade-down.sshs-animated {
    animation: sshsFadeInDown var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--fade-left.sshs-animated {
    animation: sshsFadeInLeft var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--fade-right.sshs-animated {
    animation: sshsFadeInRight var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--scale-in.sshs-animated {
    animation: sshsScaleIn var(--sshs-animation-duration, 0.6s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--zoom-in.sshs-animated {
    animation: sshsZoomIn var(--sshs-animation-duration, 0.5s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--bounce-in.sshs-animated {
    animation: sshsBounceIn var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--slide-bottom.sshs-animated {
    animation: sshsSlideInBottom var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  .sshs-animate--slide-top.sshs-animated {
    animation: sshsSlideInTop var(--sshs-animation-duration, 0.8s) var(--sshs-animation-easing, cubic-bezier(0.25, 0.46, 0.45, 0.94)) forwards;
    animation-delay: var(--sshs-animation-delay, 0s);
  }

  /* Staggered animation delays for children */
  .sshs-stagger > *:nth-child(1) { --sshs-animation-delay: 0s; }
  .sshs-stagger > *:nth-child(2) { --sshs-animation-delay: 0.1s; }
  .sshs-stagger > *:nth-child(3) { --sshs-animation-delay: 0.2s; }
  .sshs-stagger > *:nth-child(4) { --sshs-animation-delay: 0.3s; }
  .sshs-stagger > *:nth-child(5) { --sshs-animation-delay: 0.4s; }
  .sshs-stagger > *:nth-child(6) { --sshs-animation-delay: 0.5s; }

  /* ════════════════════════════════════
     PAGE LOADING ANIMATION
     ════════════════════════════════════ */

  /* Shimmer Loading Effect */
  @keyframes sshsShimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }

  .sshs-loading {
    position: relative;
    overflow: hidden;
  }

  .sshs-loading::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgb(255 255 255 / 0.3) 50%,
      transparent 100%
    );
    background-size: 200% 100%;
    animation: sshsShimmer 1.5s infinite;
    z-index: 100;
    pointer-events: none;
  }

  /* Pulse Loading Effect */
  @keyframes sshsPulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  .sshs-loading--pulse {
    animation: sshsPulse 1.5s ease-in-out infinite;
  }

  /* Fade In Loading Effect */
  @keyframes sshsFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .sshs-loading--fade {
    animation: sshsFadeIn 0.5s ease-out forwards;
  }

  /* Spinner Loading */
  @keyframes sshsSpin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .sshs-spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgb(255 255 255 / 0.3);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: sshsSpin 0.8s linear infinite;
  }

  /* Page Load Overlay */
  .sshs-page-load-overlay {
    position: fixed;
    inset: 0;
    background: var(--sshs-page-load-bg, #ffffff);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .sshs-page-load-overlay.sshs-loaded {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* ════════════════════════════════════
     HOVER ANIMATIONS
     ════════════════════════════════════ */

  /* Button Hover Effects */
  .sshs-btn {
    transition: transform 160ms ease, filter 160ms ease, box-shadow 160ms ease, background-color 160ms ease, border-color 160ms ease;
  }

  .sshs-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px -8px rgb(0 0 0 / 0.3);
  }

  .sshs-btn:active {
    transform: translateY(0);
  }

  /* Button Glow Effect */
  .sshs-btn--glow {
    position: relative;
    overflow: hidden;
  }

  .sshs-btn--glow::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgb(255 255 255 / 0.2), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }

  .sshs-btn--glow:hover::before {
    transform: translateX(100%);
  }

  /* Button Ripple Effect */
  .sshs-btn--ripple {
    position: relative;
    overflow: hidden;
  }

  .sshs-btn--ripple::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    background: radial-gradient(circle, rgb(255 255 255 / 0.3) 0%, transparent 70%);
    transform: scale(0);
    opacity: 0;
    transition: transform 0.5s ease, opacity 0.5s ease;
  }

  .sshs-btn--ripple:hover::after {
    transform: scale(2);
    opacity: 1;
  }

  /* Media Hover Effects */
  .sshs-media--hover-zoom .sshs-media__img,
  .sshs-media--hover-zoom .sshs-media__video {
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .sshs-media--hover-zoom:hover .sshs-media__img,
  .sshs-media--hover-zoom:hover .sshs-media__video {
    transform: scale(1.08);
  }

  /* Media Lift Effect */
  .sshs-media--hover-lift {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
  }

  .sshs-media--hover-lift:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px -15px rgb(0 0 0 / 0.3);
  }

  /* Media Shine Effect */
  .sshs-media--hover-shine {
    position: relative;
    overflow: hidden;
  }

  .sshs-media--hover-shine::before {
    content: '';
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgb(255 255 255 / 0.3),
      transparent
    );
    transform: skewX(-25deg);
    transition: left 0.75s ease;
    z-index: 2;
    pointer-events: none;
  }

  .sshs-media--hover-shine:hover::before {
    left: 125%;
  }

  /* Content Box Hover Effects */
  .sshs-content--hover-lift {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s ease;
  }

  .sshs-content--hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px -10px rgb(0 0 0 / 0.2);
  }

  /* Content Box Glow Border */
  .sshs-content--hover-glow {
    position: relative;
  }

  .sshs-content--hover-glow::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: linear-gradient(45deg, #ff0080, #ff8c00, #40e0d0, #ff0080);
    background-size: 300% 300%;
    opacity: 0;
    z-index: -1;
    transition: opacity 0.3s ease;
    animation: sshsGlowRotate 3s linear infinite;
  }

  .sshs-content--hover-glow:hover::before {
    opacity: 1;
  }

  @keyframes sshsGlowRotate {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Arrow Hover Effects */
  .sshs-arrow {
    transition: transform 200ms ease, background-color 200ms ease, box-shadow 200ms ease;
  }

  .sshs-arrow:hover {
    transform: scale(1.1);
    background: rgb(0 0 0 / 0.5);
    box-shadow: 0 4px 15px rgb(0 0 0 / 0.3);
  }

  .sshs-arrow:active {
    transform: scale(0.95);
  }

  /* Pagination Bullet Hover */
  .sshs-pagination .swiper-pagination-bullet {
    transition: transform 200ms ease, background-color 200ms ease;
  }

  .sshs-pagination .swiper-pagination-bullet:hover {
    transform: scale(1.2);
  }

  /* Kicker Hover Effect */
  .sshs-kicker {
    transition: letter-spacing 300ms ease;
  }

  .sshs-kicker:hover {
    letter-spacing: 2px;
  }

  /* Heading Hover Effect */
  .sshs-heading {
    transition: color 300ms ease;
  }

  /* Subheading Hover Effect */
  .sshs-subheading {
    transition: opacity 300ms ease;
  }

  .sshs-subheading:hover {
    opacity: 1;
  }

  /* ════════════════════════════════════
     REDUCED MOTION SUPPORT
     ════════════════════════════════════ */

  @media (prefers-reduced-motion: reduce) {
    .sshs-animate--fade-up,
    .sshs-animate--fade-down,
    .sshs-animate--fade-left,
    .sshs-animate--fade-right,
    .sshs-animate--scale-in,
    .sshs-animate--zoom-in,
    .sshs-animate--bounce-in,
    .sshs-animate--slide-bottom,
    .sshs-animate--slide-top,
    .sshs-media--floating .sshs-media__img,
    .sshs-media--floating-mobile .sshs-media__img,
    .sshs-loading::before,
    .sshs-loading--pulse,
    .sshs-spinner {
      animation: none !important;
    }

    .sshs-btn,
    .sshs-media--hover-zoom .sshs-media__img,
    .sshs-media--hover-zoom .sshs-media__video,
    .sshs-media--hover-lift,
    .sshs-content--hover-lift,
    .sshs-arrow,
    .sshs-pagination .swiper-pagination-bullet {
      transition: none !important;
    }

    .sshs-media--hover-shine::before,
    .sshs-btn--glow::before {
      display: none;
    }
  }

  .sshs-nav {
    position: absolute;
    inset-inline: 0;
    top: 50%;
    display: flex;
    justify-content: space-between;
    transform: translateY(-50%);
    padding-inline: 12px;
    pointer-events: none;
    z-index: 10;
  }

  .sshs-arrow {
    pointer-events: auto;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid rgb(255 255 255 / 0.25);
    background: rgb(0 0 0 / 0.35);
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .sshs-arrow .svg-wrapper {
    width: 18px;
    height: 18px;
  }

  .sshs-pagination {
    position: absolute;
    inset-inline: 0;
    bottom: 12px;
    display: flex;
    justify-content: center;
    z-index: 10;
  }

  @media screen and (max-width: 749px) {
    .sshs-nav {
      top: auto;
      bottom: 14px;
      transform: none;
    }
  }
{% endstylesheet %}

