{% liquid
  assign custom_font_url = section.settings.custom_font_url | strip
  assign custom_font_family = section.settings.custom_font_family | strip | remove: '"' | remove: "'"
  assign inherit_theme_fonts = section.settings.inherit_theme_fonts
  
  assign font_apply_heading = section.settings.font_apply_heading
  assign font_apply_kicker = section.settings.font_apply_kicker
  assign font_apply_subheading = section.settings.font_apply_subheading
  assign font_apply_buttons = section.settings.font_apply_buttons
  
  assign slider_height = section.settings.slider_height | default: 'auto'
  assign slider_custom_height = section.settings.slider_custom_height | append: 'px'
  assign slider_mobile_height = section.settings.slider_mobile_height | append: 'px'
%}

{% if custom_font_url != blank %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="{{ custom_font_url | escape }}" rel="stylesheet">
{% endif %}

{% liquid
  assign bg_image_desktop = section.settings.background_image_desktop
  assign bg_image_mobile = section.settings.background_image_mobile
  assign bg_video_desktop = section.settings.background_video_desktop
  assign bg_video_mobile = section.settings.background_video_mobile
  assign bg_video_muted_desktop = section.settings.background_video_muted_desktop
  assign bg_video_loop_desktop = section.settings.background_video_loop_desktop
  assign bg_video_muted_mobile = section.settings.background_video_muted_mobile
  assign bg_video_loop_mobile = section.settings.background_video_loop_mobile
  assign bg_size_desktop = section.settings.background_size_desktop | default: 'cover'
  assign bg_size_mobile = section.settings.background_size_mobile | default: 'cover'
  assign bg_position_desktop = section.settings.background_position_desktop | default: 'center center'
  assign bg_position_mobile = section.settings.background_position_mobile | default: 'center center'
  assign bg_overlay_opacity_desktop = section.settings.background_overlay_opacity_desktop | default: 0.5
  assign bg_overlay_color_desktop = section.settings.background_overlay_color_desktop | default: '#000000'
  assign bg_overlay_opacity_mobile = section.settings.background_overlay_opacity_mobile | default: 0.5
  assign bg_overlay_color_mobile = section.settings.background_overlay_color_mobile | default: '#000000'
%}

{% comment %} Video takes priority over image if both are uploaded {% endcomment %}
{% assign has_bg_desktop = false %}
{% if bg_video_desktop != blank %}
  {% assign has_bg_desktop = true %}
  {% assign bg_media_type_desktop = 'video' %}
{% elsif bg_image_desktop != blank %}
  {% assign has_bg_desktop = true %}
  {% assign bg_media_type_desktop = 'image' %}
{% endif %}

{% assign has_bg_mobile = false %}
{% if bg_video_mobile != blank %}
  {% assign has_bg_mobile = true %}
  {% assign bg_media_type_mobile = 'video' %}
{% elsif bg_image_mobile != blank %}
  {% assign has_bg_mobile = true %}
  {% assign bg_media_type_mobile = 'image' %}
{% endif %}

{% if has_bg_desktop or has_bg_mobile %}
  {% assign has_bg_media = true %}
{% else %}
  {% assign has_bg_media = false %}
{% endif %}

{% liquid
  assign padding_top_desktop = section.settings.padding_top_desktop | append: 'px'
  assign padding_right_desktop = section.settings.padding_right_desktop | append: 'px'
  assign padding_bottom_desktop = section.settings.padding_bottom_desktop | append: 'px'
  assign padding_left_desktop = section.settings.padding_left_desktop | append: 'px'
  assign margin_top_desktop = section.settings.margin_top_desktop | append: 'px'
  assign margin_bottom_desktop = section.settings.margin_bottom_desktop | append: 'px'
  assign padding_top_mobile = section.settings.padding_top_mobile | append: 'px'
  assign padding_right_mobile = section.settings.padding_right_mobile | append: 'px'
  assign padding_bottom_mobile = section.settings.padding_bottom_mobile | append: 'px'
  assign padding_left_mobile = section.settings.padding_left_mobile | append: 'px'
  assign margin_top_mobile = section.settings.margin_top_mobile | append: 'px'
  assign margin_bottom_mobile = section.settings.margin_bottom_mobile | append: 'px'
%}

{% assign has_custom_font = false %}
{% if custom_font_family != blank and custom_font_family != '' %}
  {% assign has_custom_font = true %}
{% endif %}

<split-screen-hero-slider
  class="split-screen-hero-slider{% if inherit_theme_fonts %} sshs--theme-fonts{% endif %}{% if has_custom_font %} sshs--custom-font{% endif %}{% if slider_height == 'full' %} sshs--full-height{% elsif slider_height == 'custom' %} sshs--custom-height{% endif %}"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}"
  data-loop="{{ section.settings.loop }}"
  data-keyboard="{{ section.settings.keyboard }}"
  data-page-load-animation="{{ section.settings.enable_page_load_animation }}"
  data-page-load-bg="{{ section.settings.page_load_background }}"
  style="--sshs-padding-top: {{ padding_top_desktop }}; --sshs-padding-right: {{ padding_right_desktop }}; --sshs-padding-bottom: {{ padding_bottom_desktop }}; --sshs-padding-left: {{ padding_left_desktop }}; --sshs-margin-top: {{ margin_top_desktop }}; --sshs-margin-bottom: {{ margin_bottom_desktop }}; --sshs-padding-top-mobile: {{ padding_top_mobile }}; --sshs-padding-right-mobile: {{ padding_right_mobile }}; --sshs-padding-bottom-mobile: {{ padding_bottom_mobile }}; --sshs-padding-left-mobile: {{ padding_left_mobile }}; --sshs-margin-top-mobile: {{ margin_top_mobile }}; --sshs-margin-bottom-mobile: {{ margin_bottom_mobile }};{% if has_custom_font %}--sshs-custom-font: '{{ custom_font_family }}';--sshs-font-heading: {% if font_apply_heading %}{{ custom_font_family }}{% else %}inherit{% endif %};--sshs-font-kicker: {% if font_apply_kicker %}{{ custom_font_family }}{% else %}inherit{% endif %};--sshs-font-subheading: {% if font_apply_subheading %}{{ custom_font_family }}{% else %}inherit{% endif %};--sshs-font-buttons: {% if font_apply_buttons %}{{ custom_font_family }}{% else %}inherit{% endif %};{% endif %}{% if slider_height == 'custom' %}--sshs-height: {{ slider_custom_height }};{% endif %}--sshs-mobile-height: {{ slider_mobile_height }};"
>
  {% if has_bg_media %}
    <div class="sshs-bg-media" aria-hidden="true">
      {% if has_bg_desktop %}
        {% if bg_media_type_desktop == 'video' and bg_video_desktop != blank %}
          <div class="sshs-bg-video-wrapper sshs-bg-video-wrapper--desktop">
            {{ bg_video_desktop | video_tag: class: 'sshs-bg-video sshs-bg-video--desktop', autoplay: true, muted: bg_video_muted_desktop, loop: bg_video_loop_desktop, playsinline: true }}
          </div>
          <style>
            .sshs-bg-video-wrapper--desktop video {
              object-fit: {{ bg_size_desktop }};
              object-position: {{ bg_position_desktop }};
            }
          </style>
        {% elsif bg_media_type_desktop == 'image' and bg_image_desktop != blank %}
          <img
            class="sshs-bg-img sshs-bg-img--desktop"
            src="{{ bg_image_desktop | image_url: width: 2000 }}"
            srcset="{{ bg_image_desktop | image_url: width: 1200 }} 1200w, {{ bg_image_desktop | image_url: width: 1600 }} 1600w, {{ bg_image_desktop | image_url: width: 2000 }} 2000w"
            sizes="100vw"
            width="{{ bg_image_desktop.width }}"
            height="{{ bg_image_desktop.height }}"
            alt=""
            loading="eager"
            fetchpriority="high"
            style="object-fit: {{ bg_size_desktop }}; object-position: {{ bg_position_desktop }};"
          >
        {% endif %}
      {% endif %}
      {% if has_bg_mobile %}
        {% if bg_media_type_mobile == 'video' and bg_video_mobile != blank %}
          <div class="sshs-bg-video-wrapper sshs-bg-video-wrapper--mobile">
            {{ bg_video_mobile | video_tag: class: 'sshs-bg-video sshs-bg-video--mobile', autoplay: true, muted: bg_video_muted_mobile, loop: bg_video_loop_mobile, playsinline: true }}
          </div>
          <style>
            .sshs-bg-video-wrapper--mobile video {
              object-fit: {{ bg_size_mobile }};
              object-position: {{ bg_position_mobile }};
            }
          </style>
        {% elsif bg_media_type_mobile == 'image' and bg_image_mobile != blank %}
          <img
            class="sshs-bg-img sshs-bg-img--mobile"
            src="{{ bg_image_mobile | image_url: width: 1200 }}"
            srcset="{{ bg_image_mobile | image_url: width: 600 }} 600w, {{ bg_image_mobile | image_url: width: 900 }} 900w, {{ bg_image_mobile | image_url: width: 1200 }} 1200w"
            sizes="100vw"
            width="{{ bg_image_mobile.width }}"
            height="{{ bg_image_mobile.height }}"
            alt=""
            loading="eager"
            fetchpriority="high"
            style="object-fit: {{ bg_size_mobile }}; object-position: {{ bg_position_mobile }};"
          >
        {% endif %}
      {% endif %}
      <div class="sshs-bg-overlay sshs-bg-overlay--desktop" style="background: {{ bg_overlay_color_desktop }}; opacity: {{ bg_overlay_opacity_desktop }};"></div>
      <div class="sshs-bg-overlay sshs-bg-overlay--mobile" style="background: {{ bg_overlay_color_mobile }}; opacity: {{ bg_overlay_opacity_mobile }};"></div>
    </div>
  {% endif %}
  <div class="swiper" data-split-screen-hero-swiper>
    <div class="swiper-wrapper">
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          {% liquid
            assign desktop_position = block.settings.desktop_media_position | default: 'left'
            assign content_order_mobile = block.settings.mobile_media_position | default: 'above'
            assign hide_media = block.settings.hide_media

            assign heading_tag = block.settings.heading_size | default: 'h1'
            assign subheading_tag = block.settings.subheading_size | default: 'p'

            assign desktop_padding_style = '--sshs-padding-x: ' | append: block.settings.desktop_padding_x | append: 'px; --sshs-padding-y: ' | append: block.settings.desktop_padding_y | append: 'px;'
            assign mobile_padding_style = '--sshs-padding-x-mobile: ' | append: block.settings.mobile_padding_x | append: 'px; --sshs-padding-y-mobile: ' | append: block.settings.mobile_padding_y | append: 'px;'

            assign desktop_margin_style = '--sshs-margin-y: ' | append: block.settings.desktop_margin_y | append: 'px;'
            assign mobile_margin_style = '--sshs-margin-y-mobile: ' | append: block.settings.mobile_margin_y | append: 'px;'

            assign content_radius_desktop = block.settings.content_radius_desktop | append: 'px'
            assign content_border_width_desktop = block.settings.content_border_width_desktop | append: 'px'
            assign content_radius_mobile = block.settings.content_radius_mobile | append: 'px'
            assign content_border_width_mobile = block.settings.content_border_width_mobile | append: 'px'

            assign image_radius_desktop = block.settings.media_radius_desktop | append: 'px'
            assign image_border_width_desktop = block.settings.media_border_width_desktop | append: 'px'
            assign image_radius_mobile = block.settings.media_radius_mobile | append: 'px'
            assign image_border_width_mobile = block.settings.media_border_width_mobile | append: 'px'

            assign media_padding_x_desktop = block.settings.media_padding_x_desktop | append: 'px'
            assign media_padding_y_desktop = block.settings.media_padding_y_desktop | append: 'px'
            assign media_margin_x_desktop = block.settings.media_margin_x_desktop | append: 'px'
            assign media_padding_x_mobile = block.settings.media_padding_x_mobile | append: 'px'
            assign media_padding_y_mobile = block.settings.media_padding_y_mobile | append: 'px'
            assign media_margin_x_mobile = block.settings.media_margin_x_mobile | append: 'px'

            assign media_align_desktop = block.settings.media_alignment_desktop | default: 'center'
            assign media_valign_desktop = block.settings.media_vertical_alignment_desktop | default: 'center'
            assign media_object_fit_desktop = block.settings.media_object_fit_desktop | default: 'cover'
            assign media_align_mobile = block.settings.media_alignment_mobile | default: 'center'
            assign media_valign_mobile = block.settings.media_vertical_alignment_mobile | default: 'center'
            assign media_object_fit_mobile = block.settings.media_object_fit_mobile | default: 'cover'
            assign blend_mode_desktop = block.settings.css_blend_mode_desktop | default: 'normal'
            assign blend_mode_mobile = block.settings.css_blend_mode_mobile | default: 'normal'
            assign content_bg_opacity_desktop = block.settings.content_bg_opacity_desktop | default: 0.0
            assign content_bg_opacity_mobile = block.settings.content_bg_opacity_mobile | default: 0.0

            assign content_align = block.settings.content_alignment | default: 'left'
            assign content_align_mobile = block.settings.content_alignment_mobile | default: 'center'
            assign content_max_width = block.settings.content_max_width | append: 'px'
            assign grid_gap = block.settings.grid_gap | append: 'px'
            assign buttons_vertical_desktop = block.settings.buttons_vertical_desktop
            assign buttons_vertical_mobile = block.settings.buttons_vertical_mobile

            assign btn_radius_desktop = block.settings.button_radius_desktop | append: 'px'
            assign btn_border_width_desktop = block.settings.button_border_width_desktop | append: 'px'
            assign btn_radius_mobile = block.settings.button_radius_mobile | append: 'px'
            assign btn_border_width_mobile = block.settings.button_border_width_mobile | append: 'px'
            assign has_glass_desktop = block.settings.enable_glass_desktop
            assign has_glass_mobile = block.settings.enable_glass_mobile
            assign floating_desktop = block.settings.enable_floating_desktop
            assign floating_mobile = block.settings.enable_floating_mobile
            assign letter_spacing_desktop = block.settings.letter_spacing_desktop | append: 'px'
            assign letter_spacing_mobile = block.settings.letter_spacing_mobile | append: 'px'
            assign font_weight_desktop = block.settings.font_weight_desktop
            assign font_weight_mobile = block.settings.font_weight_mobile
            assign heading_size_desktop = block.settings.heading_font_size_desktop | append: 'px'
            assign heading_size_mobile = block.settings.heading_font_size_mobile | append: 'px'
            assign subheading_size_desktop = block.settings.subheading_font_size_desktop | append: 'px'
            assign subheading_size_mobile = block.settings.subheading_font_size_mobile | append: 'px'

            assign enable_stroke_desktop = block.settings.enable_text_stroke_desktop
            assign stroke_width_desktop = block.settings.text_stroke_width_desktop | append: 'px'
            assign stroke_color_desktop = block.settings.text_stroke_color_desktop
            assign enable_stroke_mobile = block.settings.enable_text_stroke_mobile
            assign stroke_width_mobile = block.settings.text_stroke_width_mobile | append: 'px'
            assign stroke_color_mobile = block.settings.text_stroke_color_mobile

            assign content_animation = block.settings.content_animation | default: 'none'
            assign media_animation = block.settings.media_animation | default: 'none'
            assign animation_duration = block.settings.animation_duration | default: 0.8
            assign animation_delay = block.settings.animation_delay | default: 0

            assign button_hover_effect = block.settings.button_hover_effect | default: 'lift'
            assign media_hover_effect = block.settings.media_hover_effect | default: 'none'
            assign content_hover_effect = block.settings.content_hover_effect | default: 'none'

            assign media_filter_desktop = ''
            if block.settings.enable_grayscale_desktop
              assign media_filter_desktop = media_filter_desktop | append: ' grayscale(1)'
            endif
            if block.settings.brightness_desktop != 100
              assign brightness_value = block.settings.brightness_desktop | divided_by: 100.0
              assign media_filter_desktop = media_filter_desktop | append: ' brightness(' | append: brightness_value | append: ')'
            endif
            assign media_filter_desktop = media_filter_desktop | strip

            assign media_filter_mobile = ''
            if block.settings.enable_grayscale_mobile
              assign media_filter_mobile = media_filter_mobile | append: ' grayscale(1)'
            endif
            if block.settings.brightness_mobile != 100
              assign brightness_value = block.settings.brightness_mobile | divided_by: 100.0
              assign media_filter_mobile = media_filter_mobile | append: ' brightness(' | append: brightness_value | append: ')'
            endif
            assign media_filter_mobile = media_filter_mobile | strip

            assign overlay_opacity_desktop = block.settings.overlay_opacity_desktop | default: 0.0
            assign media_opacity_desktop = block.settings.media_opacity_desktop | default: 1
            assign overlay_opacity_mobile = block.settings.overlay_opacity_mobile | default: 0.0
            assign media_opacity_mobile = block.settings.media_opacity_mobile | default: 1

            assign fetchpriority = 'auto'
            if section.settings.fetchpriority_first_slide and forloop.first
              assign fetchpriority = 'high'
            endif

            assign loading_attr = 'lazy'
            if section.settings.eager_first_slide and forloop.first
              assign loading_attr = 'eager'
            endif
          %}

          <div
            class="swiper-slide"
            {{ block.shopify_attributes }}
          >
            <div
              class="sshs-slide"
              style="
                {{ desktop_padding_style }}
                {{ mobile_padding_style }}
                {{ desktop_margin_style }}
                {{ mobile_margin_style }}
                --sshs-content-bg-opacity: {{ content_bg_opacity_desktop }};
                --sshs-content-bg-opacity-mobile: {{ content_bg_opacity_mobile }};
                --sshs-media-opacity: {{ media_opacity_desktop }};
                --sshs-media-opacity-mobile: {{ media_opacity_mobile }};
                --sshs-overlay-opacity: {{ overlay_opacity_desktop }};
                --sshs-overlay-opacity-mobile: {{ overlay_opacity_mobile }};
                --sshs-content-radius: {{ content_radius_desktop }};
                --sshs-content-radius-mobile: {{ content_radius_mobile }};
                --sshs-content-border-width: {{ content_border_width_desktop }};
                --sshs-content-border-width-mobile: {{ content_border_width_mobile }};
                --sshs-media-radius: {{ image_radius_desktop }};
                --sshs-media-radius-mobile: {{ image_radius_mobile }};
                --sshs-media-border-width: {{ image_border_width_desktop }};
                --sshs-media-border-width-mobile: {{ image_border_width_mobile }};
                --sshs-button-radius: {{ btn_radius_desktop }};
                --sshs-button-radius-mobile: {{ btn_radius_mobile }};
                --sshs-button-border-width: {{ btn_border_width_desktop }};
                --sshs-button-border-width-mobile: {{ btn_border_width_mobile }};
                --sshs-letter-spacing: {{ letter_spacing_desktop }};
                --sshs-letter-spacing-mobile: {{ letter_spacing_mobile }};
              "
              data-desktop-position="{{ desktop_position }}"
              data-mobile-media-position="{{ content_order_mobile }}"
              data-hide-media="{{ hide_media }}"
            >
              {% liquid
                assign content_column_class = 'sshs-col sshs-col--content'
                assign media_column_class = 'sshs-col sshs-col--media'

                if hide_media
                  assign content_column_class = content_column_class | append: ' sshs-col--full-width sshs-col--no-media'
                  assign media_column_class = media_column_class | append: ' sshs-col--hidden'
                elsif desktop_position == 'right'
                  assign content_column_class = content_column_class | append: ' sshs-col--left'
                  assign media_column_class = media_column_class | append: ' sshs-col--right'
                else
                  assign content_column_class = content_column_class | append: ' sshs-col--right'
                  assign media_column_class = media_column_class | append: ' sshs-col--left'
                endif
              %}

              <div class="sshs-grid{% if hide_media %} sshs-grid--no-media{% endif %}" style="--sshs-grid-gap: {{ grid_gap }};">
                <div class="{{ content_column_class }}" data-desktop-align="{{ content_align }}" data-mobile-align="{{ content_align_mobile }}">
                  <div
                    class="sshs-content{% if has_glass_desktop %} sshs-content--glass{% endif %}{% if has_glass_mobile %} sshs-content--glass-mobile{% endif %}{% if content_animation != 'none' %} sshs-animate--{{ content_animation }}{% endif %}{% if content_hover_effect == 'lift' %} sshs-content--hover-lift{% elsif content_hover_effect == 'glow' %} sshs-content--hover-glow{% endif %}"
                    data-align="{{ content_align }}"
                    data-align-mobile="{{ content_align_mobile }}"
                    style="
                      --sshs-content-bg: {{ block.settings.content_bg_color_desktop }};
                      --sshs-content-bg-mobile: {{ block.settings.content_bg_color_mobile }};
                      --sshs-content-border: {{ block.settings.content_border_color_desktop }};
                      --sshs-content-border-mobile: {{ block.settings.content_border_color_mobile }};
                      --sshs-text-color: {{ block.settings.text_color_desktop }};
                      --sshs-text-color-mobile: {{ block.settings.text_color_mobile }};
                      --sshs-content-max-width: {{ content_max_width }};
                      --sshs-content-align: {{ content_align }};
                      --sshs-content-align-mobile: {{ content_align_mobile }};
                      --sshs-heading-size: {{ heading_size_desktop }};
                      --sshs-heading-size-mobile: {{ heading_size_mobile }};
                      --sshs-subheading-size: {{ subheading_size_desktop }};
                      --sshs-subheading-size-mobile: {{ subheading_size_mobile }};
                      --sshs-font-weight: {{ font_weight_desktop }};
                      --sshs-font-weight-mobile: {{ font_weight_mobile }};
                      --sshs-text-stroke-width: {{ stroke_width_desktop }};
                      --sshs-text-stroke-width-mobile: {{ stroke_width_mobile }};
                      --sshs-text-stroke-color: {{ stroke_color_desktop }};
                      --sshs-text-stroke-color-mobile: {{ stroke_color_mobile }};
                      --sshs-enable-stroke: {{ enable_stroke_desktop }};
                      --sshs-enable-stroke-mobile: {{ enable_stroke_mobile }};
                      --sshs-animation-duration: {{ animation_duration }}s;
                      --sshs-animation-delay: {{ animation_delay }}s;
                    "
                  >
                    {% if block.settings.kicker != blank %}
                      <div class="sshs-kicker" style="color: var(--sshs-text-color);">
                        {{ block.settings.kicker }}
                      </div>
                    {% endif %}

                    {% if block.settings.heading != blank %}
                      <{{ heading_tag }}
                        class="sshs-heading"
                        style="
                          color: var(--sshs-text-color);
                          font-size: var(--sshs-heading-size);
                          letter-spacing: var(--sshs-letter-spacing);
                          font-weight: var(--sshs-font-weight, inherit);
                          -webkit-text-stroke: var(--sshs-text-stroke-width, 0) var(--sshs-text-stroke-color, transparent);
                        "
                      >
                        {{ block.settings.heading }}
                      </{{ heading_tag }}>
                    {% endif %}

                    {% if block.settings.subheading != blank %}
                      <{{ subheading_tag }}
                        class="sshs-subheading"
                        style="
                          color: var(--sshs-text-color);
                          font-size: var(--sshs-subheading-size);
                          letter-spacing: var(--sshs-letter-spacing);
                          font-weight: var(--sshs-font-weight, inherit);
                        "
                      >
                        {{ block.settings.subheading }}
                      </{{ subheading_tag }}>
                    {% endif %}

                    {% if block.settings.primary_cta_label != blank or block.settings.secondary_cta_label != blank %}
                      <div class="sshs-cta-row{% if buttons_vertical_desktop %} sshs-cta-row--vertical{% endif %}{% if buttons_vertical_mobile %} sshs-cta-row--vertical-mobile{% endif %}">
                        {% if block.settings.primary_cta_label != blank %}
                          <a
                            class="sshs-btn sshs-btn--primary{% if button_hover_effect == 'glow' %} sshs-btn--glow{% elsif button_hover_effect == 'ripple' %} sshs-btn--ripple{% endif %}"
                            href="{{ block.settings.primary_cta_link | default: routes.all_products_collection_url }}"
                            style="
                              --sshs-btn-bg: {{ block.settings.primary_button_bg_desktop }};
                              --sshs-btn-bg-mobile: {{ block.settings.primary_button_bg_mobile }};
                              --sshs-btn-color: {{ block.settings.primary_button_text_desktop }};
                              --sshs-btn-color-mobile: {{ block.settings.primary_button_text_mobile }};
                              --sshs-btn-border: {{ block.settings.primary_button_border_desktop }};
                              --sshs-btn-border-mobile: {{ block.settings.primary_button_border_mobile }};
                            "
                          >
                            {{ block.settings.primary_cta_label }}
                          </a>
                        {% endif %}

                        {% if block.settings.secondary_cta_label != blank %}
                          <a
                            class="sshs-btn sshs-btn--secondary{% if button_hover_effect == 'glow' %} sshs-btn--glow{% elsif button_hover_effect == 'ripple' %} sshs-btn--ripple{% endif %}"
                            href="{{ block.settings.secondary_cta_link | default: routes.all_products_collection_url }}"
                            style="
                              --sshs-btn-bg: {{ block.settings.secondary_button_bg_desktop }};
                              --sshs-btn-bg-mobile: {{ block.settings.secondary_button_bg_mobile }};
                              --sshs-btn-color: {{ block.settings.secondary_button_text_desktop }};
                              --sshs-btn-color-mobile: {{ block.settings.secondary_button_text_mobile }};
                              --sshs-btn-border: {{ block.settings.secondary_button_border_desktop }};
                              --sshs-btn-border-mobile: {{ block.settings.secondary_button_border_mobile }};
                            "
                          >
                            {{ block.settings.secondary_cta_label }}
                          </a>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                </div>

                <div class="{{ media_column_class }}">
                  <div
                    class="sshs-media{% if floating_desktop %} sshs-media--floating{% endif %}{% if floating_mobile %} sshs-media--floating-mobile{% endif %}{% if media_animation != 'none' %} sshs-animate--{{ media_animation }}{% endif %}{% if media_hover_effect == 'zoom' %} sshs-media--hover-zoom{% elsif media_hover_effect == 'lift' %} sshs-media--hover-lift{% elsif media_hover_effect == 'shine' %} sshs-media--hover-shine{% endif %}"
                    style="
                      --sshs-media-border: {{ block.settings.media_border_color_desktop }};
                      --sshs-media-border-mobile: {{ block.settings.media_border_color_mobile }};
                      --sshs-overlay: {{ block.settings.overlay_color_desktop }};
                      --sshs-overlay-mobile: {{ block.settings.overlay_color_mobile }};
                      --sshs-overlay-opacity: {{ overlay_opacity_desktop }};
                      --sshs-overlay-opacity-mobile: {{ overlay_opacity_mobile }};
                      --sshs-media-opacity: {{ media_opacity_desktop }};
                      --sshs-media-opacity-mobile: {{ media_opacity_mobile }};
                      --sshs-media-padding-x: {{ media_padding_x_desktop }};
                      --sshs-media-padding-x-mobile: {{ media_padding_x_mobile }};
                      --sshs-media-padding-y: {{ media_padding_y_desktop }};
                      --sshs-media-padding-y-mobile: {{ media_padding_y_mobile }};
                      --sshs-media-margin-x: {{ media_margin_x_desktop }};
                      --sshs-media-margin-x-mobile: {{ media_margin_x_mobile }};
                      --sshs-media-blend: {{ blend_mode_desktop }};
                      --sshs-media-blend-mobile: {{ blend_mode_mobile }};
                      --sshs-media-align: {{ media_align_desktop }};
                      --sshs-media-align-mobile: {{ media_align_mobile }};
                      --sshs-media-valign: {{ media_valign_desktop }};
                      --sshs-media-valign-mobile: {{ media_valign_mobile }};
                      --sshs-media-object-fit: {{ media_object_fit_desktop }};
                      --sshs-media-object-fit-mobile: {{ media_object_fit_mobile }};
                      --sshs-animation-duration: {{ animation_duration }}s;
                      --sshs-animation-delay: {{ animation_delay }}s;
                      {% if media_filter_desktop != blank %}--sshs-media-filter: {{ media_filter_desktop }};{% endif %}
                      {% if media_filter_mobile != blank %}--sshs-media-filter-mobile: {{ media_filter_mobile }};{% endif %}
                    "
                  >
                    <div class="sshs-overlay" aria-hidden="true"></div>

                    {% liquid
                      assign desktop_image = block.settings.desktop_image
                      assign desktop_video = block.settings.desktop_video
                      assign mobile_image = block.settings.mobile_image
                      assign mobile_video = block.settings.mobile_video
                      assign video_autoplay_desktop = block.settings.video_autoplay_desktop
                      assign video_muted_desktop = block.settings.video_muted_desktop
                      assign video_loop_desktop = block.settings.video_loop_desktop
                      assign video_controls_desktop = block.settings.video_controls_desktop
                      assign video_autoplay_mobile = block.settings.video_autoplay_mobile
                      assign video_muted_mobile = block.settings.video_muted_mobile
                      assign video_loop_mobile = block.settings.video_loop_mobile
                      assign video_controls_mobile = block.settings.video_controls_mobile
                      
                      assign has_desktop_media = false
                      assign has_mobile_media = false
                      
                      if desktop_video != blank
                        assign has_desktop_media = true
                        assign desktop_media_type = 'video'
                      elsif desktop_image != blank
                        assign has_desktop_media = true
                        assign desktop_media_type = 'image'
                      endif
                      
                      if mobile_video != blank
                        assign has_mobile_media = true
                        assign mobile_media_type = 'video'
                      elsif mobile_image != blank
                        assign has_mobile_media = true
                        assign mobile_media_type = 'image'
                      endif
                    %}

                    {% if has_desktop_media or has_mobile_media %}
                      <div class="sshs-media__wrapper" data-desktop-type="{{ desktop_media_type }}" data-mobile-type="{{ mobile_media_type }}">
                        {%- comment -%} Desktop Media {%- endcomment -%}
                        {% if desktop_media_type == 'video' and desktop_video != blank %}
                          {{ desktop_video | video_tag: class: 'sshs-media__video sshs-media__video--desktop', autoplay: video_autoplay_desktop, muted: video_muted_desktop, loop: video_loop_desktop, controls: video_controls_desktop, playsinline: true }}
                        {% elsif desktop_media_type == 'image' and desktop_image != blank %}
                          <img
                            class="sshs-media__img sshs-media__img--desktop"
                            src="{{ desktop_image | image_url: width: 1600 }}"
                            srcset="{{ desktop_image | image_url: width: 900 }} 900w, {{ desktop_image | image_url: width: 1200 }} 1200w, {{ desktop_image | image_url: width: 1600 }} 1600w, {{ desktop_image | image_url: width: 2000 }} 2000w"
                            sizes="(min-width: 750px) 50vw, 100vw"
                            width="{{ desktop_image.width }}"
                            height="{{ desktop_image.height }}"
                            alt="{{ desktop_image.alt | default: 'Slide image' | escape }}"
                            loading="{{ loading_attr }}"
                            fetchpriority="{{ fetchpriority }}"
                          >
                        {% endif %}

                        {%- comment -%} Mobile Media {%- endcomment -%}
                        {% if mobile_media_type == 'video' and mobile_video != blank %}
                          {{ mobile_video | video_tag: class: 'sshs-media__video sshs-media__video--mobile', autoplay: video_autoplay_mobile, muted: video_muted_mobile, loop: video_loop_mobile, controls: video_controls_mobile, playsinline: true }}
                        {% elsif mobile_media_type == 'image' and mobile_image != blank %}
                          <img
                            class="sshs-media__img sshs-media__img--mobile"
                            src="{{ mobile_image | image_url: width: 1200 }}"
                            srcset="{{ mobile_image | image_url: width: 900 }} 900w, {{ mobile_image | image_url: width: 1200 }} 1200w"
                            sizes="100vw"
                            width="{{ mobile_image.width }}"
                            height="{{ mobile_image.height }}"
                            alt="{{ mobile_image.alt | default: 'Slide image' | escape }}"
                            loading="{{ loading_attr }}"
                          >
                        {% endif %}
                      </div>
                    {% else %}
                      <div class="sshs-media__placeholder">
                        <span>Upload media</span>
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.show_arrows %}
      <div class="sshs-nav">
        <button type="button" class="sshs-arrow sshs-arrow--prev" aria-label="Previous slide">
          {{ 'icon-chevron-left.svg' | inline_asset_content }}
        </button>
        <button type="button" class="sshs-arrow sshs-arrow--next" aria-label="Next slide">
          {{ 'icon-chevron-right.svg' | inline_asset_content }}
        </button>
      </div>
    {% endif %}

    {% if section.settings.show_pagination %}
      <div class="sshs-pagination" aria-hidden="true"></div>
    {% endif %}
  </div>
</split-screen-hero-slider>

<script
  src="{{ 'split-screen-hero-slider.js' | asset_url }}"
  type="module"
></script>

{% stylesheet %}
  /* Typography - Custom Font Support */
  .split-screen-hero-slider {
    --sshs-font-family: var(--sshs-custom-font, var(--font-body-family, inherit));
    --sshs-heading-font-family: var(--sshs-custom-font, var(--font-heading-family, inherit));
  }

  /* Inherit Theme Fonts - only apply when custom font is NOT set */
  .sshs--theme-fonts:not(.sshs--custom-font) .sshs-heading,
  .sshs--theme-fonts:not(.sshs--custom-font) .sshs-kicker {
    font-family: var(--font-heading-family, inherit);
  }

  .sshs--theme-fonts:not(.sshs--custom-font) .sshs-subheading,
  .sshs--theme-fonts:not(.sshs--custom-font) .sshs-btn {
    font-family: var(--font-body-family, inherit);
  }

  /* Custom Font - apply to specific elements based on settings */
  .sshs--custom-font .sshs-heading {
    font-family: var(--sshs-font-heading, var(--font-heading-family, inherit)) !important;
  }

  .sshs--custom-font .sshs-kicker {
    font-family: var(--sshs-font-kicker, var(--font-heading-family, inherit)) !important;
  }

  .sshs--custom-font .sshs-subheading {
    font-family: var(--sshs-font-subheading, var(--font-body-family, inherit)) !important;
  }

  .sshs--custom-font .sshs-btn {
    font-family: var(--sshs-font-buttons, var(--font-body-family, inherit)) !important;
  }

  .split-screen-hero-slider {
    display: block;
    position: relative;
    padding: var(--sshs-padding-top, 0) var(--sshs-padding-right, 0) var(--sshs-padding-bottom, 0) var(--sshs-padding-left, 0);
    margin-top: var(--sshs-margin-top, 0);
    margin-bottom: var(--sshs-margin-bottom, 0);
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    margin-right: calc(-50vw + 50%);
    overflow: hidden;
  }

  @media screen and (max-width: 749px) {
    .split-screen-hero-slider {
      padding: var(--sshs-padding-top-mobile, 0) var(--sshs-padding-right-mobile, 0) var(--sshs-padding-bottom-mobile, 0) var(--sshs-padding-left-mobile, 0);
      margin-top: var(--sshs-margin-top-mobile, 0);
      margin-bottom: var(--sshs-margin-bottom-mobile, 0);
    }
  }

  /* Slider height controls */
  .split-screen-hero-slider.sshs--full-height {
    min-height: 100vh;
  }

  .split-screen-hero-slider.sshs--full-height .swiper {
    min-height: 100vh;
    height: 100%;
  }

  .split-screen-hero-slider.sshs--full-height .swiper-wrapper,
  .split-screen-hero-slider.sshs--full-height .swiper-slide {
    height: 100%;
  }

  .split-screen-hero-slider.sshs--custom-height {
    min-height: var(--sshs-height, 600px);
  }

  .split-screen-hero-slider.sshs--custom-height .swiper {
    min-height: var(--sshs-height, 600px);
    height: 100%;
  }

  .split-screen-hero-slider.sshs--custom-height .swiper-wrapper,
  .split-screen-hero-slider.sshs--custom-height .swiper-slide {
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .split-screen-hero-slider.sshs--full-height,
    .split-screen-hero-slider.sshs--custom-height {
      min-height: var(--sshs-mobile-height, 500px);
    }

    .split-screen-hero-slider.sshs--full-height .swiper,
    .split-screen-hero-slider.sshs--custom-height .swiper {
      min-height: var(--sshs-mobile-height, 500px);
    }
  }

  .split-screen-hero-slider .swiper {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .sshs-bg-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .sshs-bg-img,
  .sshs-bg-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sshs-bg-img--mobile,
  .sshs-bg-video--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .sshs-bg-img--desktop,
    .sshs-bg-video--desktop {
      display: none;
    }

    .sshs-bg-img--mobile,
    .sshs-bg-video--mobile {
      display: block;
    }
  }

  .sshs-bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .sshs-slide {
    margin-block: var(--sshs-margin-y, 0px);
    background: transparent;
    background-color: transparent;
  }

  .split-screen-hero-slider.sshs--full-height .sshs-slide,
  .split-screen-hero-slider.sshs--custom-height .sshs-slide {
    height: 100%;
    display: flex;
    align-items: stretch;
  }

  .split-screen-hero-slider.sshs--full-height .sshs-slide .sshs-grid,
  .split-screen-hero-slider.sshs--full-height .sshs-slide .sshs-col,
  .split-screen-hero-slider.sshs--full-height .sshs-slide .sshs-media,
  .split-screen-hero-slider.sshs--custom-height .sshs-slide .sshs-grid,
  .split-screen-hero-slider.sshs--custom-height .sshs-slide .sshs-col,
  .split-screen-hero-slider.sshs--custom-height .sshs-slide .sshs-media {
    height: 100%;
  }

  .split-screen-hero-slider.sshs--full-height .sshs-slide .sshs-grid,
  .split-screen-hero-slider.sshs--custom-height .sshs-slide .sshs-grid {
    flex: 1 1 auto;
    align-items: stretch;
  }

  @media screen and (max-width: 749px) {
    .sshs-slide {
      margin-block: var(--sshs-margin-y-mobile, var(--sshs-margin-y, 0px));
    }
  }

  .sshs-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--sshs-grid-gap, 40px);
    align-items: stretch;
    background: transparent;
    background-color: transparent;
  }

  /* Grid with no media - content takes full width */
  .sshs-grid--no-media {
    grid-template-columns: 1fr;
    display: flex;
    justify-content: center;
  }

  .sshs-grid--no-media .sshs-col--content {
    flex: 0 0 100%;
    width: 100%;
    max-width: 100%;
  }

  /* Desktop alignment when media hidden - use justify-content on parent column */
  .sshs-col--no-media[data-desktop-align="left"] {
    justify-content: flex-start;
  }

  .sshs-col--no-media[data-desktop-align="center"] {
    justify-content: center;
  }

  .sshs-col--no-media[data-desktop-align="right"] {
    justify-content: flex-end;
  }

  @media screen and (min-width: 750px) {
    .sshs-col--no-media .sshs-content {
      align-items: var(--sshs-content-align, flex-start);
    }

    .sshs-col--no-media[data-desktop-align="center"] .sshs-content {
      align-items: center;
    }

    .sshs-col--no-media[data-desktop-align="right"] .sshs-content {
      align-items: flex-end;
    }
  }

  @media screen and (max-width: 749px) {
    .sshs-grid {
      grid-template-columns: 1fr;
    }

    .sshs-grid--no-media {
      display: grid;
    }

    .sshs-col--no-media[data-mobile-align="left"] {
      justify-content: flex-start;
    }

    .sshs-col--no-media[data-mobile-align="center"] {
      justify-content: center;
    }

    .sshs-col--no-media[data-mobile-align="right"] {
      justify-content: flex-end;
    }
  }

  .sshs-col {
    min-width: 0;
    display: flex;
    background: transparent;
    background-color: transparent;
    flex: 1 1 0;
    min-height: 0;
  }

  .sshs-col--media {
    flex: 1 1 0;
    display: flex;
    background: transparent;
    background-color: transparent;
  }

  /* Content column full width when media hidden */
  .sshs-col--full-width {
    flex: 0 0 100%;
    width: 100%;
    max-width: 100%;
  }

  /* Hide media column */
  .sshs-col--hidden {
    display: none;
  }

  /* Desktop: Default order (content left, media right) */
  .sshs-col--content.sshs-col--left {
    order: 1;
  }
  .sshs-col--media.sshs-col--right {
    order: 2;
  }

  /* Desktop: Media on left (content right) */
  .sshs-col--media.sshs-col--left {
    order: 1;
  }
  .sshs-col--content.sshs-col--right {
    order: 2;
  }

  /* Mobile: Default stacking (content above media) */
  @media screen and (max-width: 749px) {
    .sshs-col--content {
      order: 1 !important;
    }
    .sshs-col--media {
      order: 2 !important;
    }

    /* Mobile: Media above content */
    [data-mobile-media-position="above"] .sshs-col--media {
      order: 1 !important;
    }
    [data-mobile-media-position="above"] .sshs-col--content {
      order: 2 !important;
    }
  }

  .sshs-content {
    width: 100%;
    max-width: var(--sshs-content-max-width, 800px);
    align-self: center;
    padding: var(--sshs-padding-y, 40px) var(--sshs-padding-x, 40px);
    border-radius: var(--sshs-content-radius, 24px);
    border: var(--sshs-content-border-width, 0px) solid var(--sshs-content-border, transparent);
    background: var(--sshs-content-bg, transparent);
    background-color: color-mix(in oklab, var(--sshs-content-bg, transparent) calc(var(--sshs-content-bg-opacity, 0) * 100%), transparent);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  /* Content alignment when media IS visible */
  @media screen and (min-width: 750px) {
    .sshs-content[data-align="center"] {
      align-items: center;
      text-align: center;
    }

    .sshs-content[data-align="right"] {
      align-items: flex-end;
      text-align: right;
    }

    .sshs-content[data-align="left"] {
      align-items: flex-start;
      text-align: left;
    }
  }

  @media screen and (max-width: 749px) {
    .sshs-content {
      padding: var(--sshs-padding-y-mobile, var(--sshs-padding-y, 40px)) var(--sshs-padding-x-mobile, var(--sshs-padding-x, 24px));
      border-radius: var(--sshs-content-radius-mobile, var(--sshs-content-radius, 24px));
      border-width: var(--sshs-content-border-width-mobile, var(--sshs-content-border-width, 0px));
      background: var(--sshs-content-bg-mobile, var(--sshs-content-bg, transparent));
      background-color: color-mix(in oklab, var(--sshs-content-bg-mobile, var(--sshs-content-bg, transparent)) calc(var(--sshs-content-bg-opacity-mobile, var(--sshs-content-bg-opacity, 0)) * 100%), transparent);
    }

    .sshs-content[data-align-mobile="center"] {
      align-items: center;
      text-align: center;
    }

    .sshs-content[data-align-mobile="right"] {
      align-items: flex-end;
      text-align: right;
    }

    .sshs-content[data-align-mobile="left"] {
      align-items: flex-start;
      text-align: left;
    }
  }

  .sshs-content--glass {
