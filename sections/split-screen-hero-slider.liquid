      font-size: var(--sshs-subheading-size-mobile, var(--sshs-subheading-size));
      letter-spacing: var(--sshs-letter-spacing-mobile, var(--sshs-letter-spacing));
      font-weight: var(--sshs-font-weight-mobile, var(--sshs-font-weight, inherit));
    }
  }

  .sshs-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
    width: 100%;
  }

  /* Button row alignment follows content alignment */
  .sshs-content[data-align="center"] .sshs-cta-row {
    justify-content: center;
  }

  .sshs-content[data-align="right"] .sshs-cta-row {
    justify-content: flex-end;
  }

  .sshs-content[data-align="left"] .sshs-cta-row {
